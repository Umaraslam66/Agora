# environments
.venv/

# python cruft
__pycache__/
*.pyc
*.egg-info/
dist/
.pytest_cache/
.ruff_cache/

# OS cruft
.DS_Store

# large run artifacts (run manifests/scores that back README claims stay tracked)
runs/**/*.ckpt
runs/**/*.safetensors
runs/**/*.bin
runs/**/*.pt
runs/**/*.parquet
runs/**/*.log
runs/**/*.jsonl.gz

# large/raw data — never commit microdata; small synthetic samples ARE tracked
data/**
!data/synthetic/
!data/synthetic/*.jsonl

# Internal records — public repo, so gate records, sealed decisions, the defects
# register, design drafts, and the project brief are NOT published; they live only
# on the owner's machine. (git rm --cached keeps them on disk; they ARE the record
# of decisions — see CLAUDE.md "Local-only records".)
docs/
/00_PROJECT_BRIEF.md

# Personal Claude Code overrides (the shared BT1 guard in .claude/settings.json
# stays tracked so it protects fresh clones and CI)
.claude/settings.local.json

# Raw survey downloads (public data, but bulky and license-respectful to not mirror)
data/psrc/

# Per-site cluster env (real account/venv/HF-cache paths) — never committed;
# jobs/site_env.example.sh (placeholder paths) is the tracked template.
jobs/site_env.sh

# record-derived card sets are never committed (privacy discipline)
runs/**/cards*.jsonl
data/cards/
# rewrite round-trip artifacts embed full card content (same discipline)
runs/**/accepted_cards*.jsonl
runs/**/requests_round*.json
runs/**/prompts_round*.jsonl

# record-derived content pulled for local diagnostics (cards/generations) — NEVER commit
ignore/
